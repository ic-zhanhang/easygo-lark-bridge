# 复制为 easygo.env 后填写：cp config/easygo.env.example config/easygo.env

# ── 部署 profile ────────────────────────────────────────────
# mac = 达妮娅（Mac，默认）；linux 见 config/easygo.env.linux.example
BRIDGE_PROFILE=mac

# ── 授权操作者（私聊或群聊 @Bot 可触发）────────────────────
# open_id：lark-cli auth status（自己）或群消息日志 / 会话 jsonl 里的 sender
# 多人用逗号分隔；ALLOWED_OPERATOR_NAMES 与 open_id 顺序对应（可选）
ALLOWED_OPERATOR_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxx,ou_yyyyyyyyyyyyyyyyyyyyyyyy
ALLOWED_OPERATOR_NAMES=杨展航,同事甲
# 兼容旧配置（仅单人时可只填此项）
# ALLOWED_OPERATOR_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxx

# ── 路径 ────────────────────────────────────────────────────
# workspace 根（easygo / standard-fe 所在目录）
WORKSPACE_ROOT=/Users/ic/workspace

# 以下默认由 install.sh 推导，一般不必改：
#   claw/     → ${本仓库}/claw
#   runtime/  → ${本仓库}/runtime
# RUNTIME_DIR=
# CLAW_INSTALL_DIR=

EASYGO_WORKSPACE_FILE=/Users/ic/workspace/easygo-dev.code-workspace

# ── 飞书应用（与 lark-cli 共用）────────────────────────────
FEISHU_APP_ID=cli_a94621950d785bb3
FEISHU_APP_SECRET=

# ── Cursor Agent ────────────────────────────────────────────
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# ── GitLab CI / MR（HEARTBEAT 可选，不填则跳过）──────────────
GITLAB_API=http://git.standard-robots.com/api/v4
GITLAB_PRIVATE_TOKEN=
GITLAB_BACKEND_PROJECT=SROS/platforms/easygo
GITLAB_FRONTEND_PROJECT=standard-fe/easygo
