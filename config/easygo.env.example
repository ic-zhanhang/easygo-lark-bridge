# 复制为 easygo.env 后填写：cp config/easygo.env.example config/easygo.env

# ── 部署 profile ────────────────────────────────────────────
# mac = 达妮娅（Mac，默认）；linux 见 config/easygo.env.linux.example
BRIDGE_PROFILE=mac

# ── 聊天权限与授权人（权限分级）────────────────────────────
# L1 AUTHORIZER：唯一可授予/撤销他人聊天权限（杨展航）
# L2 CHAT_OPERATOR_*：可 @Bot 聊天的人（须含 AUTHORIZER）
# ⚠️ open_id 必须是【本 Bot App】视角：看 Claw 日志 [解析] sender=ou_xxx，或 L1 发「授权 @某人」由 Claw 自动写入
#    不要用 Mac lark-cli / 其它 Bot 查到的 id（同一人跨 App 的 open_id 不同）
AUTHORIZER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxx
AUTHORIZER_NAME=杨展航
CHAT_OPERATOR_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxx
CHAT_OPERATOR_NAMES=杨展航

# ── 路径 ────────────────────────────────────────────────────
# workspace 根（easygo / standard-fe 所在目录）
WORKSPACE_ROOT=/Users/ic/workspace

# 以下默认由 install.sh 推导，一般不必改：
#   claw/     → ${本仓库}/claw
#   runtime/  → ${本仓库}/runtime
# RUNTIME_DIR=
# CLAW_INSTALL_DIR=

EASYGO_WORKSPACE_FILE=/Users/ic/workspace/easygo-dev.code-workspace

# ── 飞书应用（与 lark-cli 共用）────────────────────────────
FEISHU_APP_ID=cli_a94621950d785bb3
FEISHU_APP_SECRET=

# ── 可选：豆包 Embedding（记忆向量检索，不填则仅 FTS 关键词搜索）──
# VOLC_EMBEDDING_API_KEY=
# VOLC_EMBEDDING_MODEL=doubao-embedding-vision-250615

# ── Cursor Agent ────────────────────────────────────────────
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# ── GitLab CI / MR（HEARTBEAT 可选，不填则跳过）──────────────
GITLAB_API=http://git.standard-robots.com/api/v4
GITLAB_PRIVATE_TOKEN=
GITLAB_BACKEND_PROJECT=SROS/platforms/easygo
GITLAB_FRONTEND_PROJECT=standard-fe/easygo
