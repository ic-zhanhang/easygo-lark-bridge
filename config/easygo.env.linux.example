# Linux 秧秧 — 复制为 easygo.env 后填写：
#   cp config/easygo.env.linux.example config/easygo.env

# ── 部署 profile（安装脚本会读取）────────────────────────────
BRIDGE_PROFILE=linux

# ── 授权操作者 ─────────────────────────────────────────────
ALLOWED_OPERATOR_OPEN_IDS=ou_xxxxxxxxxxxxxxxxxxxxxxxx
ALLOWED_OPERATOR_NAMES=杨展航

# ── 路径（按 Linux 用户 home 修改）──────────────────────────
WORKSPACE_ROOT=/home/std/workspace
EASYGO_WORKSPACE_FILE=/home/std/workspace/easygo-dev.code-workspace

# ── 飞书应用（秧秧 — 须与 Mac 达妮娅不同的 App）────────────
FEISHU_APP_ID=cli_xxxxxxxxxxxxxxxx
FEISHU_APP_SECRET=

# ── Cursor Agent ────────────────────────────────────────────
CURSOR_API_KEY=
CURSOR_MODEL=composer-2.5

# ── systemd（可选）──────────────────────────────────────────
# SERVICE_LABEL=com.ic.lark-assistant
# SYSTEMD_UNIT=lark-assistant.service

# ── GitLab CI / MR（心跳可选）──────────────────────────────
GITLAB_API=http://git.standard-robots.com/api/v4
GITLAB_PRIVATE_TOKEN=
GITLAB_BACKEND_PROJECT=SROS/platforms/easygo
GITLAB_FRONTEND_PROJECT=standard-fe/easygo
